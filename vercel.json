{
  "rewrites": [
    {
      "source": "/auth/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/users/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/dashboard/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/menu/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/tables/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/orders/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/payments/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/cash/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/audit/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/printer-profiles/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/print/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/index.html",
      "destination": "/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
